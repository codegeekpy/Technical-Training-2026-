# Standardize line endings to LF for all text files (standard for Java/JS/CSS projects)
* text=auto eol=lf

# Explicitly handle specific file types
*.java text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.xml text eol=lf
*.properties text eol=lf
*.md text eol=lf
*.json text eol=lf

# Don't touch binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
